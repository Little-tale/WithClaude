{
  "claudeCli": {
    "command": "claude",
    "commonArgs": ["-p", "--output-format", "json"],
    "timeoutMs": 900000,
    // Choose one of: haiku, sonnet, opus
    "defaultModel": "sonnet",
    "roles": {
      "planClaude": {
        "args": ["--permission-mode", "plan"]
      },
      "implClaude": {
        "args": ["--permission-mode", "acceptEdits", "--add-dir", "{{workspaceRoot}}"]
      },
      "reviewClaude": {
        "args": ["--permission-mode", "plan"]
      }
    }
  }
}
