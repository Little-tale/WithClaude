{
  "name": "opencode-with-claude",
  "version": "0.1.0",
  "private": false,
  "description": "Claude CLI provider and workflow plugin surfaces for OpenCode.",
  "type": "module",
  "files": [
    "dist/**/*",
    ".opencode/agents/**/*",
    ".opencode/command/**/*",
    ".opencode/opencode-with-claude.jsonc",
    "README.md",
    ".env.example"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./plugin": {
      "import": "./dist/plugin-entry.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:mcp": "tsx watch src/mcp-main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "start": "node dist/main.js",
    "start:mcp": "node dist/mcp-main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@opencode-ai/plugin": "^1.2.24",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
